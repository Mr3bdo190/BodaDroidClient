<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_dark"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Control Panel"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_slate"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Account (Blogger)"
            android:textColor="#94A3B8"
            android:layout_marginBottom="8dp"/>
            
        <Button
            android:id="@+id/connectGoogleBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Connect Blogger 🔗"
            android:background="@drawable/bg_btn_slate"
            android:textColor="#EA4335"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/bloggerStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Disconnected ❌"
            android:textColor="#EF4444"
            android:textSize="12sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Model Key"
            android:textColor="#94A3B8"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Gemini API Key..."
            android:textColorHint="#64748B"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_input_cyber"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/saveSettingsBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE CONFIGURATION"
            android:background="@drawable/bg_btn_neon"
            android:textColor="#00E5FF"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
