<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_slate"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New AI Article ✨"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/topicInput"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Article Topic"
        android:textColorHint="#64748B"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_input_cyber"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/nicheInput"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Niche (e.g. Tech)"
        android:textColorHint="#64748B"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_input_cyber"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/instructionsInput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Keywords, Tone..."
        android:textColorHint="#64748B"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_input_cyber"
        android:padding="16dp"
        android:gravity="top|start"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/confirmGenerateBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="GENERATE &amp; PUBLISH"
        android:background="@drawable/bg_btn_neon"
        android:textColor="#00E5FF"
        android:textStyle="bold"/>
</LinearLayout>
